+cerrarSesion(): boolean
+cambiarContraseña(username: String, oldPassword: String, newPassword: String): boolean

#Métodos exclusivos del gestor
+crearEmpleado(username: String, dni: String): boolean
+eliminarEmpleado(e: Empleado): boolean

#Métodos para las estadísticas
