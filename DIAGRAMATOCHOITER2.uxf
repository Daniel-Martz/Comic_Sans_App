-crearNotificacionOferta(o: Oferta): Notificacion
-crearNotificacionProducto(p: LineaProductoVenta): Notificacion
-crearNotificacionValidacion(p: ProductoSegundaMano): Notificacion
-crearNotificacionPedido(s: SolicitudPedido): Notificacion

#Envío de notificaciones
+enviarNotificacion(u: Usuario, notif: NotificacionUsuario): boolean


