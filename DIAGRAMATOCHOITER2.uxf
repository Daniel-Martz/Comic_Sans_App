#Metodos del Cliente Venta
+buscarProductosNuevos(prompt: String): LineaProductoVenta[*]
+añadirProductoACarrito(p:ProductoVenta)
+elimnirProductoDelCarrito(p:ProductoVenta)
-crearPedidoAPartirDeCarrito(): boolean
+realizarPagoCarrito(): boolean ???

#Metodos del Cliente Intercambio
+buscarProductoIntercambio(prompt: String, u:Usuario): ProductoSegundaMano[*]
+añadirProductoACarteraDeIntercambio(p:ProductoIntercambio)
+eliminarProductoDeCarteraDeIntercambio(p:ProductoIntercambio)
+aceptarOferta(o:Oferta, u:Usuario)
+rechazarOferta(o:Oferta, u:Usuario)
+realizarOferta(productosOfertados: PorductoIntercambio[*], productosRecibidos: PorductoIntercambio[*], destinatario:Usuario): boolean


-enviarNotificacion(u: Usuario, notif: NotificacionUsuario): boolean??? se llama desde otros metodos
#llaman a ella realizarOferta, aceptarOferta, rechazarOferta, validarProducto, pagarCarrito y prepararPedido

#Métodos para empleados
+validarProducto(s: SolicitudValidacion, precio: int, estado: EstadoConservacion): boolean
+pagarValidacion(s: SolicitudValidacion): boolean

