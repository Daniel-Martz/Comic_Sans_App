+aceptarOferta(o:Oferta, u:Usuario)
+rechazarOferta(o:Oferta, u:Usuario)

-enviarNotificacion(u: Usuario, notif: NotificacionUsuario): boolean??? se llama desde otros metodos
#llaman a ella realizarOferta, aceptarOferta, rechazarOferta, validarProducto, pagarPedido y prepararPedido

#Métodos de recomendación
+getRecomendacion(): Producto[*]

