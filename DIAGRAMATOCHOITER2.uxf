+iniciarSesion(username: String, password: String): boolean
+cerrarSesion(): boolean
+cambiarContraseña(username: String, oldPassword: String, newPassword: String): boolean

#Métodos exclusivos del gestor
+añadirEmpleado(e: Empleado): boolean
+eliminarEmpleado(e: Empleado): boolean

#Metodos del Cliente Venta
+buscarProductosNuevos(prompt: String): LineaProductoVenta[*]
+crearPedidoAPartirDeCarrito(): boolean
+cancelarPedido(p:SolicitudPedido, u:Usuario): boolean.

#Metodos del Cliente Intercambio
+buscarProductoIntercambio(prompt: String, u:Usuario): ProductoSegundaMano[*]
+aceptarOferta(o:Oferta, u:Usuario): boolean
+rechazarOferta(o:Oferta, u:Usuario): boolean

#Métodos de recomendación
+getRecomendacion(): Producto[*]

#Métodos de Usuarios Gestión
+buscarProductoAGestionar(promptId: int): LineaProductoVenta[*]

#Métodos de pagos
+gestionarPagoPedido(p: SolicitudPedido, numTarjeta: int, cvv: int, mesCaducidad: int, añoCaducidad): boolean
+gestionarPagoValidacion(s: SolicitudValidacion, numTarjeta: int, cvv: int, mesCaducidad: int, añoCaducidad): boolean

#Notificacion Empleado
-crearNotificacionEmpleado(s: Solicitud): Notificacion

#Notificacion Cliente
