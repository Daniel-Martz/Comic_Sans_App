+eliminarEmpleado(e: Empleado): boolean
+añadirPermisoEmpleado(e: Empleado, permiso: Permiso): boolean
+eliminarPermisoEmpleado(e: Empleado, permiso: Permiso): boolean

#Métodos para las estadísticas
